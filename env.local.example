# ChooseYourProtocol — local development environment
# Copy to .env.local (gitignored). Used by the local API server (server/local-api-server.cjs).

# Firebase Admin service account JSON, base64-encoded.
# Generate from Firebase console > Project settings > Service accounts > Generate new private key,
# then: base64 -i serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT=

# Stage marker for the API (local | production)
STAGE=local
IS_OFFLINE=true

# Optional: LLM key used to score conversation "vibe" and theme generated creatures.
# If unset, the API falls back to a deterministic local generator (works offline).
GEMINI_API_KEY=
